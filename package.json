{
  "name": "shadcn-ui-framework",
  "version": "0.1.0",
  "description": "Extract a shadcn-compatible design system from public sites, then build UI in Cursor or any AI — outputs tokens, Tailwind theme, and FOR_AI.md handoff.",
  "license": "MIT",
  "keywords": [
    "shadcn",
    "tailwind",
    "design-system",
    "playwright",
    "cursor",
    "ai"
  ],
  "bin": {
    "shadcn-ui-framework": "./bin/shadcn-ui-framework.mjs"
  },
  "files": [
    "bin",
    "packages/extract",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "extract": "tsx packages/extract/extract.ts",
    "studio": "npm run dev --workspace apps/studio",
    "studio:build": "npm run build --workspace apps/studio",
    "capture": "tsx packages/capture/screenshot-site.ts",
    "analyze": "tsx packages/analysis/analyze-screenshot.ts",
    "formalize": "tsx packages/patterns/pattern-registry.ts",
    "evaluate": "tsx packages/evaluation/evaluate-page.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "playwright": "^1.48.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
